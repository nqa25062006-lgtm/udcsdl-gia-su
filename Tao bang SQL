--TẠO CƠ SỞ DỮ LIỆU
CREATE DATABASE QUAN_LY_GHEP_LOP;
GO

USE QUAN_LY_GHEP_LOP;
GO

--TẠO BẢNG NGƯỜI DÙNG
CREATE TABLE NGUOI_DUNG (
	Ma_ND			CHAR(10) PRIMARY KEY,
	Ho_Ten			NVARCHAR(255) NOT NULL,
	SDT				CHAR(11) NOT NULL UNIQUE,
	Dia_Chi			NVARCHAR(255) NOT NULL
);

--TẠO BẢNG TÀI KHOẢN
CREATE TABLE TAI_KHOAN (	
	Ma_TK			VARCHAR(10) PRIMARY KEY,
	Ten_Dang_Nhap	VARCHAR(50) NOT NULL,
	MK				VARCHAR(50) NOT NULL,
	Ma_ND			CHAR(10) FOREIGN KEY REFERENCES NGUOI_DUNG(Ma_ND) NOT NULL
);

--TẠO BẢNG PHỤ HUYNH
CREATE TABLE PHU_HUYNH (
	Ma_PH			CHAR(10) PRIMARY KEY,
	Quan_He			NVARCHAR(10),
	Ma_ND			CHAR(10) FOREIGN KEY REFERENCES NGUOI_DUNG(Ma_ND) NOT NULL
);

--TẠO BẢNG GIA SƯ 
CREATE TABLE GIA_SU (
	Ma_GS			CHAR(10) PRIMARY KEY,
	Trinh_Do		CHAR(2) CHECK (Trinh_Do in('SV', 'GV') )NOT NULL,
	Kinh_Nghiem		NVARCHAR(255),
	Chung_Chi		NVARCHAR(50),
	Bang_Cap		NVARCHAR(50),
	Ma_ND			CHAR(10) FOREIGN KEY REFERENCES NGUOI_DUNG(Ma_ND) NOT NULL
);

--TẠO BẢNG MÔN
CREATE TABLE MON (
	Ma_Mon			VARCHAR(10) PRIMARY KEY,
	Ten_Mon			NVARCHAR(50) NOT NULL
);

--TẠO BẢNG KHU VỰC
CREATE TABLE KHU_VUC (
	Ma_Khu_Vuc		VARCHAR(10) PRIMARY KEY,
	Ten_Khu_Vuc		NVARCHAR(255) NOT NULL
);

--TẠO BẢNG YCML
CREATE TABLE YCML (
	Ma_YCML			CHAR(10) PRIMARY KEY,
	Lop				INTEGER NOT NULL,
	Thoi_Gian_DK	NVARCHAR(255) NOT NULL,
	Hoc_Phi			INTEGER NOT NULL,
	Yeu_Cau_GS		CHAR(10) NOT NULL,
	Ngay_Lap		DATE NOT NULL,
	Ngay_Thay_Doi	DATE,
	Ma_GS			CHAR(10) FOREIGN KEY REFERENCES GIA_SU(Ma_GS) NOT NULL,
	Ma_Mon			VARCHAR(10) FOREIGN KEY REFERENCES MON(Ma_Mon) NOT NULL,
	Ma_Khu_Vuc		VARCHAR(10) FOREIGN KEY REFERENCES KHU_VUC(Ma_Khu_Vuc) NOT NULL
);

--TẠO BẢNG TRẠNG THÁI YÊU CẦU
CREATE TABLE TT_YEU_CAU (
	Ma_TTYC			VARCHAR(10) PRIMARY KEY,
	Ten_TT			NVARCHAR(255) NOT NULL
);

--TẠO BẢNG LỊCH SỬ TRẠNG THÁI
CREATE TABLE LICH_SU_TT (
	Ma_TTYC			VARCHAR(10) FOREIGN KEY REFERENCES TT_YEU_CAU(Ma_TTYC) NOT NULL,
	Ma_YCML			CHAR(10) FOREIGN KEY REFERENCES YCML(Ma_YCML) NOT NULL,
	NgayDoiTT		DATE,
	CONSTRAINT PK_LSTT PRIMARY KEY(Ma_TTYC, Ma_YCML)
);


--TẠO BẢNG ỨNG TUYỂN
CREATE TABLE UNG_TUYEN (
	NgayUT			DATE NOT NULL,
	TTUT			NVARCHAR(255) NOT NULL,
	Ma_GS			Char(10) FOREIGN KEY REFERENCES GIA_SU(Ma_GS) NOT NULL,
	Ma_YCML			Char(10) FOREIGN KEY REFERENCES YCML(Ma_YCML) NOT NULL,
	CONSTRAINT PK_UT PRIMARY KEY(Ma_GS, Ma_YCML)
);

--TẠO BẢNG HỢP ĐỒNG
CREATE TABLE HOP_DONG (
	Ma_HD			CHAR(10) PRIMARY KEY,
	Ngay_BD			DATE NOT NULL,
	Ngay_KT			DATE NOT NULL,
	Constraint CHECK_Ngay CHECK (Ngay_KT >= Ngay_BD),
	Phi_Nhan_Lop	INTEGER NOT NULL,
	Ngay_Tao		DATE NOT NULL,
	Trang_Thai		NVARCHAR(255) NOT NULL,
	Ma_GS			CHAR(10) FOREIGN KEY REFERENCES GIA_SU(Ma_GS) NOT NULL,
	Ma_YCML			CHAR(10) FOREIGN KEY REFERENCES YCML(Ma_YCML) NOT NULL
);

--TẠO BẢNG LOẠI PHÁT SINH
CREATE TABLE LOAI_PHAT_SINH (
	Ma_Phat_Sinh	VARCHAR(10) PRIMARY KEY,
	TenPhatSinh		NVARCHAR(255) NOT NULL,
	HinhThucXuLy	NVARCHAR(255) NOT NULL,
);

--TẠO BẢNG PHÁT SINH
CREATE TABLE PHAT_SINH (
	SoTien			INTEGER NOT NULL,
	NgayPhatSinh	DATE NOT NULL,
	MoTa			NVARCHAR(255) NOT NULL,
	Ma_Phat_Sinh    VARCHAR(10) FOREIGN KEY REFERENCES LOAI_PHAT_SINH(Ma_Phat_Sinh) NOT NULL,
	Ma_HD			CHAR(10) FOREIGN KEY REFERENCES HOP_DONG(Ma_HD) NOT NULL,
	CONSTRAINT PK_PS PRIMARY KEY(Ma_Phat_Sinh, Ma_HD)
);

--TẠO BẢNG TÌNH TRẠNG HOÁ ĐƠN
CREATE TABLE TT_HOA_DON (
	Ma_TTHD			VARCHAR(10) PRIMARY KEY,
	Ten_TT 			NVARCHAR(255) NOT NULL
);

--TẠO BẢNG HOÁ ĐƠN
CREATE TABLE HOA_DON (
	Ma_Hoa_Don		INTEGER PRIMARY KEY,
	Ngay_Lap		DATE NOT NULL,
	Tong_Tien		INTEGER NOT NULL,
	Gia_Nhan_Lop	INTEGER NOT NULL,
	Dieu_Chinh		INTEGER,
	Ma_HD			CHAR(10) FOREIGN KEY REFERENCES HOP_DONG(Ma_HD) NOT NULL,
	Ma_TTHD			VARCHAR(10) FOREIGN KEY REFERENCES TT_HOA_DON(Ma_TTHD) NOT NULL
);

--TẠO BẢNG THANH TOÁN
CREATE TABLE THANH_TOAN (
	So_Tien			INTEGER NOT NULL,
	Ngay_Thanh_Toan	DATE NOT NULL,
	Ma_Hoa_Don		INT FOREIGN KEY REFERENCES HOA_DON(Ma_Hoa_Don) NOT NULL,
	Ma_GS			CHAR(10) FOREIGN KEY REFERENCES GIA_SU(Ma_GS) NOT NULL, 
	CONSTRAINT PK_THANH_TOAN PRIMARY KEY(Ma_Hoa_Don,Ma_GS)
);


